cine:actedIn a owl:ObjectProperty ;
    rdfs:label "Acted In" ;
    rdfs:comment "Joins actors to films." ;
    rdfs:domain cine:Actor ;
    rdfs:range cine:Film ;
    owl:inverseOf cine:hasActor .

