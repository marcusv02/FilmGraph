cine:directed a owl:ObjectProperty ;
    rdfs:label "Directed" ;
    rdfs:comment "Joins directors to films." ;
    rdfs:domain cine:Director ;
    rdfs:range cine:Film ;
    owl:inverseOf cine:directedBy .

cine:directedBy a owl:ObjectProperty ;
    rdfs:label "Directed By" ;
    rdfs:comment "Joins films to directors." ;
    rdfs:domain cine:Film ;
    rdfs:range cine:Director ;
    rdfs:subPropertyOf cine:hasPerson .

cine:hasPerson a owl:ObjectProperty ;
    rdfs:label "Has Person" ;
    rdfs:comment "Joins films to people." ;
    rdfs:domain cine:Film ;
    rdfs:range cine:Person .

cine:workedWith a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "Worked With" ;
    rdfs:comment "Joins people who have worked together on a film." ;
    rdfs:domain cine:Person ;
    rdfs:range cine:Person ;
    owl:propertyChainAxiom ( cine:directed cine:hasActor ) .

