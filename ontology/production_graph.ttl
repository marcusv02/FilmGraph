cine:hasActor a owl:ObjectProperty ;
    rdfs:label "Has Actor" ;
    rdfs:comment "Joins films to actors." ;
    rdfs:domain cine:Film ;
    rdfs:range cine:Actor ;
    rdfs:subPropertyOf cine:hasPerson .

cine:Actor a owl:Class ;
    rdfs:label "Actor" ;
    rdfs:comment "An individual who performs a role in a film." ;
    rdfs:subClassOf cine:Person .

