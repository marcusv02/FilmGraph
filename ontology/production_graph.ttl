cine:Person a owl:Class ;
    rdfs:label "Person" ;
    rdfs:comment "A superclass for all actors and directors involved in a film." .

cine:Film a owl:Class ;
    rdfs:label "Film" ;
    rdfs:comment "A film from the dataset which contains the top 100 films of all time, according to IMDb." .

