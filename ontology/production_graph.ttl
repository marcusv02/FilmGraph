:avg_vote a owl:DatatypeProperty ;
    rdfs:label "Average Vote" ;
    rdfs:comment "The average numerical value a film received on a scale from 1 - 10, according to IMDb users." ;
    rdfs:domain :Film .

:coDirectedWith a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "Co-Directed With" ;
    rdfs:comment "Joins directors who have worked together on a film." ;
    rdfs:domain :Director ;
    rdfs:range :Director ;
    rdfs:subPropertyOf :workedWith ;
    owl:propertyChainAxiom ( :directed :directedBy ) .

:coStarredWith a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "Co-Starred With" ;
    rdfs:comment "Joins actors who have worked together on a film." ;
    rdfs:domain :Actor ;
    rdfs:range :Actor ;
    rdfs:subPropertyOf :workedWith ;
    owl:propertyChainAxiom ( :actedIn :hasActor ) .

:duration a owl:DatatypeProperty ;
    rdfs:label "Duration" ;
    rdfs:comment "The length of a film in minutes." ;
    rdfs:domain :Film .

:hasGenre a owl:ObjectProperty ;
    rdfs:label "Has Genre" ;
    rdfs:comment "Joins films to genres." ;
    rdfs:domain :Film ;
    rdfs:range :Genre .

:year a owl:DatatypeProperty ;
    rdfs:label "Year" ;
    rdfs:comment "The year a film released in." ;
    rdfs:domain :Film .

