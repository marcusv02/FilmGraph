cine:avg_vote a owl:DatatypeProperty ;
    rdfs:label "Average Vote" ;
    rdfs:comment "The average numerical value a film received on a scale from 1 - 10, according to IMDb users." ;
    rdfs:domain cine:Film .

cine:coDirectedWith a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "Co-Directed With" ;
    rdfs:comment "Joins directors who have worked together on a film." ;
    rdfs:domain cine:Director ;
    rdfs:range cine:Director ;
    rdfs:subPropertyOf cine:workedWith ;
    owl:propertyChainAxiom ( cine:directed cine:directedBy ) .

cine:coStarredWith a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "Co-Starred With" ;
    rdfs:comment "Joins actors who have worked together on a film." ;
    rdfs:domain cine:Actor ;
    rdfs:range cine:Actor ;
    rdfs:subPropertyOf cine:workedWith ;
    owl:propertyChainAxiom ( cine:actedIn cine:hasActor ) .

cine:duration a owl:DatatypeProperty ;
    rdfs:label "Duration" ;
    rdfs:comment "The length of a film in minutes." ;
    rdfs:domain cine:Film .

cine:hasGenre a owl:ObjectProperty ;
    rdfs:label "Has Genre" ;
    rdfs:comment "Joins films to genres." ;
    rdfs:domain cine:Film ;
    rdfs:range cine:Genre .

cine:year a owl:DatatypeProperty ;
    rdfs:label "Year" ;
    rdfs:comment "The year a film released in." ;
    rdfs:domain cine:Film .

